# SmartPaper-Tagging 環境設定範本
# 複製此檔案並重新命名為 .env，填入您的金鑰
# 或執行 smartpaper_setup.py 透過圖形介面設定

# ── 必填 ──────────────────────────────────────────────────────────────
# Google Gemini API Key（用於標籤生成、RAG 問答）
# 取得方式：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── 選填 ──────────────────────────────────────────────────────────────
# Crossref API Email（填入可加快查詢速率，遵守 polite pool 政策）
CROSSREF_EMAIL=

